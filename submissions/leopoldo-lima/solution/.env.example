# === Padrão de produção: dados REAIS (CSVs em data/). Demo só com demo_dataset explícito. ===
# Fonte de dados do processo FastAPI (ranking/dashboard servidos por esta API)
# real_dataset = CSVs oficiais em data/ (PADRÃO) | demo_dataset = data/demo-opportunities.json
LEAD_SCORER_DATA_SOURCE_MODE=real_dataset

# API client configuration (non-secret defaults)
LEAD_SCORER_REPOSITORY_MODE=api
LEAD_SCORER_API_BASE_URL=http://127.0.0.1:8787
LEAD_SCORER_API_TIMEOUT_SECONDS=5

# Optional headers for upstream integration
# LEAD_SCORER_API_AUTH_TOKEN=
# LEAD_SCORER_API_CORRELATION_ID=

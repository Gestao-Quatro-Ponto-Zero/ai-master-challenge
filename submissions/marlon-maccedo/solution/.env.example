# ─────────────────────────────────────────────────────────────────────────────
# Variáveis de ambiente — copie para .env e preencha
#
#   cp .env.example .env
#
# Este arquivo é a fonte única de configuração para:
#   • Dev local  → pnpm dev:support / pnpm dev:churn / pnpm dev:social
#   • Docker     → docker-compose up --build  (lê .env automaticamente)
#   • Railway    → configure cada variável no dashboard do serviço correspondente
# ─────────────────────────────────────────────────────────────────────────────

# OpenRouter API key — https://openrouter.ai/keys
# Usada por: churn-dashboard · support-triage · social-dashboard
# Sem esta variável os dashboards funcionam normalmente com fallback calculado;
# apenas os blocos de AI insights ficam desabilitados.
OPENROUTER_API_KEY=sk-or-v1-...

# ─────────────────────────────────────────────────────────────────────────────
# Portal — URLs dos outros services (Railway)
#
# No dashboard do service do Portal (ex.: g4-ai-master), use referências entre
# services para não fixar domínio absoluto (Railway resolve no deploy):
#
#   URL_CHURN=https://${{churn-dashboard.RAILWAY_PUBLIC_DOMAIN}}
#   URL_LEAD_SCORER=https://${{lead-scorer.RAILWAY_PUBLIC_DOMAIN}}
#   URL_SOCIAL=https://${{social-dashboard.RAILWAY_PUBLIC_DOMAIN}}
#   URL_SUPPORT=https://${{support-triage.RAILWAY_PUBLIC_DOMAIN}}
#
# Ou rode na raiz do monorepo (com `railway link` já feito):
#   pnpm railway:set-prod-vars
# (usa OPENROUTER_API_KEY e aplica as URLs acima no Portal)
# ─────────────────────────────────────────────────────────────────────────────

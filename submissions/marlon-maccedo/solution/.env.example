# ─────────────────────────────────────────────────────────────────────────────
# Variáveis de ambiente — copie para .env e preencha
#
#   cp .env.example .env
#
# Este arquivo é a fonte única de configuração para:
#   • Dev local  → pnpm dev:support / pnpm dev:churn / pnpm dev:social
#   • Docker     → docker-compose up --build  (lê .env automaticamente)
#   • Railway    → configure cada variável no dashboard do serviço correspondente
# ─────────────────────────────────────────────────────────────────────────────

# OpenRouter API key — https://openrouter.ai/keys
# Usada por: churn-dashboard · support-triage · social-dashboard
# Sem esta variável os dashboards funcionam normalmente com fallback calculado;
# apenas os blocos de AI insights ficam desabilitados.
OPENROUTER_API_KEY=sk-or-v1-...

# ─────────────────────────────────────────────────────────────────────────────
# Portal — URLs públicas dos dashboards (Railway: um service por app)
# No Railway, configure estas variáveis no service do Portal (ex.: g4-ai-master).
# Valores de exemplo abaixo; substitua pelos domínios gerados em cada service.
# ─────────────────────────────────────────────────────────────────────────────
# URL_CHURN=https://churn-dashboard-production-xxxx.up.railway.app
# URL_LEAD_SCORER=https://lead-scorer-production-xxxx.up.railway.app
# URL_SOCIAL=https://social-dashboard-production-xxxx.up.railway.app
# URL_SUPPORT=https://support-triage-production-xxxx.up.railway.app

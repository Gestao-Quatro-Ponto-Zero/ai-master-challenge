# G4 Compass - Backend Environment Variables

# Server
PORT=8080
ENV=development # Set to 'development' to enable 'admin123' password override

# Security
JWT_SECRET=sua_chave_secreta_aqui # Uma string aleatória longa para assinar o JWT

# Database
# Formato: postgres://user:password@host:port/dbname?sslmode=disable
DATABASE_URL=postgres://compass:compass@localhost:5432/compass?sslmode=disable

# Mercury LLM (Agente Co-Pilot)
MERCURY_API_KEY=your_mercury_api_key_here
MERCURY_MODEL=mercury-2

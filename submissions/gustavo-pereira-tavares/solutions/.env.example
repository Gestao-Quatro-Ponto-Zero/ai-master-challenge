# Configuração de Ambiente - Análise de Churn

# Ambiente (development, staging, production)
ENVIRONMENT=development
DEBUG=True

# API FastAPI
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=True

# Caminhos
MODEL_PATH=models
DATA_PATH=outputs
LOG_PATH=logs
DATA_INPUT_PATH=data

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Banco de dados (opcional)
# DATABASE_URL=postgresql://usuario:senha@localhost/churn_db
# SQLALCHEMY_TRACK_MODIFICATIONS=False

# Segurança
SECRET_KEY=sua-chave-secreta-aleatorio-64-caracteres-aqui-para-producao
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
CORS_ORIGINS=http://localhost:3000,http://localhost:8501

# Rate Limiting
MAX_REQUESTS_PER_MINUTE=1000
MAX_FILE_SIZE_MB=100

# Streamlit
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0
STREAMLIT_CLIENT_SHOWERRORDETAILS=True

# Monitoramento (Sentry - opcional)
# SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx
# SENTRY_ENVIRONMENT=production

# Cache
CACHE_ENABLED=True
CACHE_TTL_SECONDS=3600

# Email (para notificações - opcional)
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=seu-email@gmail.com
# SMTP_PASSWORD=sua-senha-app

# Integração CRM (opcional)
# SALESFORCE_CLIENT_ID=xxxxx
# SALESFORCE_CLIENT_SECRET=xxxxx
# HUBSPOT_API_KEY=xxxxx

# Cloud Storage (opcional)
# AWS_ACCESS_KEY_ID=xxxxx
# AWS_SECRET_ACCESS_KEY=xxxxx
# AWS_S3_BUCKET=seu-bucket-s3
# GCS_PROJECT_ID=seu-projeto-gcp
# GCS_BUCKET=seu-bucket-gcs

# Modelo ML
MODEL_THRESHOLD_CRITICAL=0.7
MODEL_THRESHOLD_HIGH=0.5
MODEL_THRESHOLD_MEDIUM=0.3
ENSEMBLE_XGB_WEIGHT=0.6
ENSEMBLE_LGB_WEIGHT=0.4

# Atualizações
AUTO_RETRAIN_ENABLED=False
RETRAIN_SCHEDULE_CRON=0 0 1 * *  # Primeiro dia do mês às 00:00

# DealSignal — Environment Variables
# Copy this file to .env and fill in your values.
# Without API keys, the enrichment pipeline falls back to deterministic mocks automatically.

# Optional: BuiltWith API key for real tech-stack enrichment
# https://api.builtwith.com/
BUILTWITH_API_KEY=your_builtwith_api_key_here

# Optional: Similarweb API key for website traffic & rank enrichment
# https://developers.similarweb.com/
SIMILARWEB_API_KEY=your_similarweb_api_key_here

# Logging verbosity: DEBUG | INFO | WARNING (default: INFO)
LOG_LEVEL=INFO

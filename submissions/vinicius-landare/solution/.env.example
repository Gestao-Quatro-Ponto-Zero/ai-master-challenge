# =============================================================
# G4 Social Metrics — Variáveis de Ambiente
# =============================================================
# Copie este arquivo para .env e preencha com suas credenciais.
# Para solicitar credenciais de demonstração: viniciusoliveira@example.com
# =============================================================

# Database (PostgreSQL)
# Instale localmente ou use Docker:
#   docker run -e POSTGRES_PASSWORD=postgres -p 5432:5432 postgres
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/social_metrics?schema=public"

# NextAuth — gere com: openssl rand -base64 32
AUTH_SECRET=""

# ─── APIs de Redes Sociais (opcional) ───────────────────────
# Necessárias apenas para coleta direta de dados
INSTAGRAM_CLIENT_ID=""
INSTAGRAM_CLIENT_SECRET=""
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""
TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""

# ─── OpenRouter (obrigatório para geração de conteúdo) ──────
# Cadastre-se em https://openrouter.ai e copie sua API key
OPENROUTER_API_KEY=""

# ─── Z-API (opcional — envio de WhatsApp) ───────────────────
# Cadastre-se em https://z-api.io, crie uma instância e copie os dados ZAPI_CLIENT_TOKEN deve ser encontrado na página segurança
ZAPI_INSTANCE_ID=""
ZAPI_TOKEN=""
ZAPI_CLIENT_TOKEN=""

# ─── Apify (opcional — análise de perfis reais) ─────────────
# Cadastre-se em https://console.apify.com e copie seu token
APIFY_TOKEN=""
